# === AI World Recreation Video Generator ===

# Required API keys
DEEPSEEK_API_KEY=sk-...        # Topic generation (~$0.001/call)
ELEVENLABS_API_KEY=...         # Ambient SFX (~$0.01/clip)
FAL_KEY=...                    # Wan 2.1 video generation (~$0.10/clip)

# YouTube auto-upload (run setup_youtube_auth.py to get these)
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REFRESH_TOKEN=...

# === Optional ===
# CLIPS_PER_VIDEO=5             # 5 clips × 5 sec = ~25 sec per video
# WAN_RESOLUTION=720p
# VIDEO_DURATION=5
# VIDEOS_PER_DAY=2
# BGM_VOLUME=0.12
# SFX_VOLUME=0.70
