# === Life-Hack Short Video Generator ===

# DeepSeek API (script generation)
DEEPSEEK_API_KEY=sk-...

# ElevenLabs (expressive TTS)
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...
ELEVENLABS_VOICE_ID_FEMALE=...

# FAL (image generation + video generation)
FAL_KEY=...

# === Optional Settings ===
# DEEPSEEK_MODEL=deepseek-chat
# ELEVENLABS_MODEL=eleven_multilingual_v2
# FAL_IMAGE_MODEL=fal-ai/flux-pro/v1.1
# FAL_VIDEO_MODEL=fal-ai/minimax/hailuo-2.3-fast/standard/image-to-video
# HAILUO_DURATION=6
# HACKS_PER_VIDEO=3
# SUBTITLE_FONT_SIZE=58
# BGM_VOLUME=0.12
# SFX_VOLUME=0.6
