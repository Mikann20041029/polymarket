# === Impossible Satisfying Video Generator ===

# Required API keys
DEEPSEEK_API_KEY=sk-...        # Concept generation (~$0.001/call)
ELEVENLABS_API_KEY=...         # ASMR sound effects (~$0.01/clip)
FAL_KEY=...                    # Video generation via Wan 2.1 (~$0.10/clip)

# === Optional Settings ===
# DEEPSEEK_MODEL=deepseek-chat
# CLIPS_PER_VIDEO=3
# VIDEO_DURATION=5              # seconds per clip (int)
# WAN_RESOLUTION=720p           # 480p or 720p
# SFX_DURATION_SECONDS=5.0      # must match VIDEO_DURATION
# BGM_VOLUME=0.15
# SFX_VOLUME=0.85
