# === AI World Recreation Video Generator ===

# Required API keys
DEEPSEEK_API_KEY=sk-...        # Topic/scene generation (~$0.001/call)
ELEVENLABS_API_KEY=...         # Ambient SFX (~$0.01/scene)
FAL_KEY=...                    # FLUX Dev images (~$0.025/image)

# === Optional Settings ===
# DEEPSEEK_MODEL=deepseek-chat
# FAL_IMAGE_MODEL=fal-ai/flux/dev       # Or fal-ai/flux-pro/v1.1 for best quality
# SCENES_PER_VIDEO=8
# SECONDS_PER_SCENE=6.0
# CROSSFADE_DURATION=0.8
# BGM_VOLUME=0.12
# SFX_VOLUME=0.70
